# MetalBear environment configuration (mirrors refpds PDS_* vars).
# Source this file (or export the METALBEAR_* vars) before running
# the `metalbear` server or the `metalbear-admin` CLI.

# --- core (required) ---
METALBEAR_PORT=2583
METALBEAR_LISTEN=127.0.0.1
METALBEAR_DATA=./data
METALBEAR_SERVICE_DID=did:web:example.com
METALBEAR_ACCOUNT_DID=did:plc:metalbear
METALBEAR_HANDLE=alice.example.com
METALBEAR_USER_DOMAIN=.example.com
METALBEAR_PASSWORD=change-me

# Public hostname used by relays/crawlers (request-crawl sends this).
METALBEAR_HOSTNAME=example.com

# --- admin (mirrors PDS_ADMIN_PASSWORD) ---
# When set, admin endpoints (com.atproto.admin.getAccountInfo) require
# HTTP Basic `admin:<this password>`. When unset they return 401.
METALBEAR_ADMIN_PASSWORD=change-me-admin

# --- crawlers/relays (mirrors PDS_CRAWLERS) ---
# Comma-separated hostnames POSTed a com.atproto.sync.requestCrawl
# when `metalbear-admin request-crawl` runs. Empty => requestCrawl
# returns an honest NoCrawlersConfigured error.
METALBEAR_CRAWLERS=https://bsky.network

# --- invite gating (mirrors PDS_INVITE_REQUIRED) ---
# 1/true => createAccount requires a non-empty inviteCode.
METALBEAR_INVITE_REQUIRED=false

# --- blob upload limit in bytes (mirrors PDS_BLOB_UPLOAD_LIMIT) ---
# 0 => unlimited.
METALBEAR_BLOB_UPLOAD_LIMIT=104857600

# --- optional email ---
# METALBEAR_SMTP_HOST=
# METALBEAR_SMTP_PORT=587
# METALBEAR_SMTP_USERNAME=
# METALBEAR_SMTP_PASSWORD=
# METALBEAR_FROM_ADDRESS=
# METALBEAR_ACCOUNT_EMAIL=admin@example.com
